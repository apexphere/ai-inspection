<header class="report-header">
  <div class="header-logo">
    {{#if companyLogo}}<img src="{{companyLogo}}" alt="Company Logo" class="logo" />{{/if}}
  </div>
  <div class="header-info">
    <h1 class="report-title">{{reportTitle}}</h1>
    <p class="report-subtitle">{{project.jobNumber}} — {{project.address}}</p>
  </div>
</header>
