<section class="report-section" id="section-6">
  <h2>6. Exterior of Building</h2>

  {{#if sections.exterior.items.length}}
  <table class="inspection-table">
    <thead>
      <tr>
        <th>Item</th>
        <th>Decision</th>
        <th>Notes</th>
      </tr>
    </thead>
    <tbody>
      {{#each sections.exterior.items}}
      <tr>
        <td>{{name}}</td>
        <td>{{{decisionBadge decision}}}</td>
        <td>{{notes}} {{{photoRefs photoNumbers}}}</td>
      </tr>
      {{/each}}
    </tbody>
  </table>
  {{else}}
  <p>No exterior observations recorded.</p>
  {{/if}}

  {{#if sections.exterior.conclusion}}
  <div class="section-conclusion exterior">{{sections.exterior.conclusion}}</div>
  {{/if}}
</section>
