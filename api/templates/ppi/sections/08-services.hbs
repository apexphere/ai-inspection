<section class="report-section" id="section-8">
  <h2>8. Service Systems</h2>

  {{#if sections.services.items.length}}
  <table class="inspection-table">
    <thead>
      <tr>
        <th>Item</th>
        <th>Decision</th>
        <th>Notes</th>
      </tr>
    </thead>
    <tbody>
      {{#each sections.services.items}}
      <tr>
        <td>{{name}}</td>
        <td>{{{decisionBadge decision}}}</td>
        <td>{{notes}} {{{photoRefs photoNumbers}}}</td>
      </tr>
      {{/each}}
    </tbody>
  </table>
  {{else}}
  <p>No service system observations recorded.</p>
  {{/if}}

  {{#if sections.services.conclusion}}
  <div class="section-conclusion services">{{sections.services.conclusion}}</div>
  {{/if}}
</section>
