<section class="report-section" id="section-5">
  <h2>5. Site and Ground Condition</h2>

  {{#if sections.site.items.length}}
  <table class="inspection-table">
    <thead>
      <tr>
        <th>Item</th>
        <th>Decision</th>
        <th>Notes</th>
      </tr>
    </thead>
    <tbody>
      {{#each sections.site.items}}
      <tr>
        <td>{{name}}</td>
        <td>{{{decisionBadge decision}}}</td>
        <td>{{notes}} {{{photoRefs photoNumbers}}}</td>
      </tr>
      {{/each}}
    </tbody>
  </table>
  {{else}}
  <p>No site and ground observations recorded.</p>
  {{/if}}

  {{#if sections.site.conclusion}}
  <div class="section-conclusion site">{{sections.site.conclusion}}</div>
  {{/if}}
</section>
