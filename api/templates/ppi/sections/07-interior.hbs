<section class="report-section" id="section-7">
  <h2>7. Interior of Building</h2>

  {{#if interior}}

  {{#if interior.living}}
  <h3>5.1 Living Areas</h3>
  <table class="inspection-table">
    <thead>
      <tr>
        <th>Item</th>
        <th>Condition</th>
        <th>Observations</th>
        <th>Photos</th>
      </tr>
    </thead>
    <tbody>
      {{#each interior.living.items}}
      <tr class="{{#if issue}}has-issue{{/if}}">
        <td>{{name}}</td>
        <td class="condition-{{lowercase condition}}">{{condition}}</td>
        <td>{{observations}}</td>
        <td>{{photoRef photoRefs}}</td>
      </tr>
      {{/each}}
    </tbody>
  </table>
  {{/if}}

  {{#if interior.kitchen}}
  <h3>5.2 Kitchen</h3>
  <table class="inspection-table">
    <thead>
      <tr>
