<section class="report-section" id="section-7">
  <h2>7. Interior of Building</h2>

  {{#if sections.interior.length}}
  {{#each sections.interior}}
  <h3>{{room}}</h3>

  {{#if items.length}}
  <table class="inspection-table">
    <thead>
      <tr>
        <th>Item</th>
        <th>Decision</th>
        <th>Notes</th>
      </tr>
    </thead>
    <tbody>
      {{#each items}}
      <tr>
        <td>{{name}}</td>
        <td>{{{decisionBadge decision}}}</td>
        <td>{{notes}} {{{photoRefs photoNumbers}}}</td>
      </tr>
      {{/each}}
    </tbody>
  </table>
  {{/if}}

  {{#if conclusion}}
  <div class="section-conclusion interior">{{conclusion}}</div>
  {{/if}}
  {{/each}}
  {{else}}
  <p>No interior observations recorded.</p>
  {{/if}}
</section>
